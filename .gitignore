# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
next-env.d.ts

# build-time generated search index (scripts/build-search-index.mjs)
/src/shared/data/search-index.json

# production
/build

# misc
.DS_Store
*.pem
temp.*

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# content images (copy-content-images.mjs 빌드 타임 생성)
public/posts

# ai
.omc
.omx

# claude
.claude/agent-memory
.claude/plans
.claude/scheduled_tasks.lock
.lint-needed-default

# harness workspace (compound engineering intermediate artifacts)
_workspace/

# mcp
.playwright-mcp
.serena

# playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# backup
.backup