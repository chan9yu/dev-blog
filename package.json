{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "dev-blog",
	"version": "1.1.0",
	"private": true,
	"engines": {
		"node": "22.x",
		"pnpm": "10.x"
	},
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"dev": "next dev --port 3100",
		"prebuild": "node scripts/copy-content-images.mjs",
		"build": "next build",
		"build:strict": "STRICT_FRONTMATTER=1 pnpm build",
		"build:vercel": "pnpm build:strict",
		"install:vercel": "bash scripts/vercel-submodule-workaround.sh && pnpm install",
		"start": "next start",
		"copy:images": "node scripts/copy-content-images.mjs",
		"lint": "eslint",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"prepare": "lefthook install"
	},
	"dependencies": {
		"@shikijs/rehype": "^4.0.2",
		"@vercel/analytics": "^2.0.1",
		"@vercel/kv": "^3.0.0",
		"@vercel/speed-insights": "^2.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dayjs": "^1.11.20",
		"framer-motion": "^12.38.0",
		"fuse.js": "^7.3.0",
		"gray-matter": "^4.0.3",
		"lucide-react": "^1.8.0",
		"next": "^16.2.3",
		"next-mdx-remote": "^6.0.0",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.4.3",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"rehype-slug": "^6.0.0",
		"remark-breaks": "^4.0.0",
		"remark-gfm": "^4.0.1",
		"shiki": "^4.0.2",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@svgr/webpack": "^8.1.0",
		"@tailwindcss/postcss": "^4.2.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitest/coverage-v8": "^4.1.4",
		"babel-plugin-react-compiler": "^1.0.0",
		"eslint": "^9.36.0",
		"eslint-config-next": "^16.2.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-simple-import-sort": "^13.0.0",
		"jsdom": "^29.0.2",
		"lefthook": "^2.1.5",
		"msw": "^2.13.2",
		"prettier": "^3.8.2",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn": "^4.2.0",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vitest": "^4.1.4"
	}
}
